{
  "name": "@git-lfs-hub/docs",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "config:vars": "git-lfs-hub-config vars .",
    "compile": "tsgo --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run compile && bun run lint && bun run format:check",
    "docmd": "bun run check && bunx docmd",
    "build": "bun run docmd build",
    "dev": "bun run docmd dev"
  },
  "devDependencies": {
    "@git-lfs-hub/config": "file:../config",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260606.1",
    "@docmd/core": "^0.8.6",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "handlebars": "^4.7.9"
  }
}
